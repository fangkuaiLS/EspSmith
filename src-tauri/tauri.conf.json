{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EspSmith",
  "identifier": "top.fago.espsmith",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "EspSmith",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' http://localhost:* https://localhost:* https://ghproxy.net https://github.com"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "msi",
      "nsis",
      "app",
      "dmg",
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": {
      "scripts/kconfig_dump.py": "scripts/",
      "binaries/codewhale.exe": ".",
      "binaries/codewhale-tui.exe": "."
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "languages": [
          "SimpChinese",
          "English"
        ]
      },
      "wix": {
        "language": "en-US",
        "bannerPath": "wix/banner.bmp",
        "dialogImagePath": "wix/dialog.bmp",
        "template": "wix/main.wxs",
        "fragmentPaths": [
          "wix/ui-theme.wxs"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {}
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDNjFGMzUwQjExQ0VENEUKUldSTzdSeXhVUE5odkVmV0gvc3NpaFFReGNuYWl4YkNCT0R4VnFFTUQxdDJ0akFWU0NBSlRIT1MK",
      "endpoints": [
        "https://github.com/fangkuaiLS/EspSmith/releases/latest/download/latest.json",
        "https://gh-proxy.com/https://github.com/fangkuaiLS/EspSmith/releases/latest/download/latest.json",
        "https://mirror.ghproxy.com/https://github.com/fangkuaiLS/EspSmith/releases/latest/download/latest.json",
        "https://ghproxy.net/https://github.com/fangkuaiLS/EspSmith/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "shell": {
      "open": true
    }
  }
}
