# Dependencies
node_modules/

# Build output
dist/
src-tauri/target/
src-tauri/.cargo/config.toml

# MinGW toolchain (too large for git, use tools/setup-mingw.ps1)
tools/mingw64/

# Tools directory (large binaries, download at build time)
tools/

# CodeWhale binary (installed at runtime via npm)
tools/codewhale/

# Bundled binaries (platform-specific, distributed via Release Assets)
# These are Windows PE files; should not be committed to cross-platform repo.
# Download via `npm run setup:binaries` or from GitHub Releases.
src-tauri/binaries/*.exe
src-tauri/binaries/*.dll

# Tauri-generated ACL schemas (auto-generated by tauri-build at compile time)
src-tauri/gen/

# WiX build artifacts (generated during MSI packaging)
src-tauri/*.wixobj
src-tauri/wix/*.wixobj

# IDE
.vscode/
.idea/
.mimocode/

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# Tauri signer private key (KEEP SECRET!)
tauri-signer.key

# Auto-generated by scripts/run-tauri.mjs for non-ASCII path workaround
.cargo-home/
.tmp/

# CodeWhale local config (contains API Key)
.codewhale/

# Log files (narrow scope: only root-level .log files)
/*.log
/logs/

# Internal working documents
PENDING_WORK.md
TASK_PLAN.md
